{
  "name": "@samjonaidi-ship-it/universal-auth",
  "version": "1.1.0-rc.5",
  "description": "Bainbridge Builders universal authentication SDK — one package, every consumer app (BB_Express, ControlTower, future Customer Portal, Buddy Console).",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/",
    "README.md",
    "docs/CHANGELOG.md",
    "docs/RELEASE_NOTES.md",
    "docs/INTEGRATION_GUIDE.md",
    "docs/THREAT_MODEL.md",
    "docs/QA_RUNBOOK.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./react": {
      "import": "./dist/esm/react/index.js",
      "types": "./dist/types/react/index.d.ts"
    },
    "./react/styles.css": "./dist/esm/react/components/styles.css",
    "./sw": {
      "import": "./dist/esm/sw/index.js",
      "types": "./dist/types/sw/index.d.ts"
    },
    "./profile": {
      "import": "./dist/esm/profile/index.js",
      "types": "./dist/types/profile/index.d.ts"
    },
    "./extendability": {
      "import": "./dist/esm/extendability/index.js",
      "types": "./dist/types/extendability/index.d.ts"
    },
    "./internal": {
      "import": "./dist/esm/internal/index.js",
      "types": "./dist/types/internal/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:browser": "playwright test",
    "test:browser:smoke": "playwright test --project=desktop-chrome --project=desktop-firefox --project=desktop-webkit --project=desktop-edge",
    "test:browser:matrix": "playwright test --project=desktop-chrome --project=desktop-firefox --project=desktop-webkit --project=desktop-edge --project=mobile-chrome --project=mobile-firefox --project=mobile-safari --project=mobile-edge --project=tablet-chrome --project=tablet-firefox --project=tablet-safari --project=tablet-edge",
    "test:browser:chromium": "playwright test --project=desktop-chrome --project=mobile-chrome --project=tablet-chrome",
    "test:browser:firefox": "playwright test --project=desktop-firefox --project=mobile-firefox --project=tablet-firefox",
    "test:browser:webkit": "playwright test --project=desktop-webkit --project=mobile-safari --project=tablet-safari",
    "test:browser:edge": "playwright test --project=desktop-edge --project=mobile-edge --project=tablet-edge",
    "test:perf": "tsx scripts/size-check-closure.ts && tsx test/perf/cold-start.ts",
    "test:chaos": "vitest run --config vitest.chaos.config.ts",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:memory": "vitest run --config vitest.memory.config.ts",
    "size-check": "tsx scripts/size-check-closure.ts",
    "verify:bundle": "tsx scripts/verify-bundle.ts",
    "verify:watermarks": "tsx scripts/verify-watermarks.ts",
    "verify:no-jose": "tsx scripts/verify-no-jose.ts",
    "verify:readme": "tsx scripts/check-readme-code.ts",
    "verify:version-sync": "tsx scripts/verify-version-sync.ts",
    "release": "tsx scripts/release.ts",
    "publish:dry": "npm publish --dry-run --provenance"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.0.0",
    "idb": "^8.0.0",
    "libphonenumber-js": "^1.10.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@pact-foundation/pact": "^16.3.0",
    "@playwright/test": "^1.47.0",
    "@simplewebauthn/server": "^13.0.0",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^3.0.0",
    "happy-dom": "^20.9.0",
    "http-server": "^14.1.0",
    "msw": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^11.0.0",
    "tiny-invariant": "^1.3.0",
    "toxiproxy-node-client": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "_comment-size-limit": "v1.1.0-rc.2 (P1-F): replaced by scripts/size-check-closure.ts. The size-limit package measures brotli of entry+all-imports (including dynamic imports), which over-counts after libphonenumber-js was lazy-loaded. Closure-aware walker is now the authoritative budget gate.",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samjonaidi-ship-it/universal-auth.git"
  }
}
