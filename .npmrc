# @bb/universal-auth | .npmrc | v1.0.0-rc.1 | 2026-04-24 | BB
# GitHub Packages registry for @bainbridgebuilders scope (must match org name; `bb` GitHub user is taken by Benjamin Bock since 2008)
# Watermarks and internal brand identifiers still use "@bb/universal-auth" for brevity
@bainbridgebuilders:registry=https://npm.pkg.github.com
# Token is set in CI via NODE_AUTH_TOKEN env; locally via ~/.npmrc with //npm.pkg.github.com/:_authToken=...
save-exact=false
engine-strict=true
