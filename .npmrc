# @samjonaidi-ship-it/universal-auth | .npmrc | v1.0.3 | 2026-05-03 | BB
# GitHub Packages registry for @samjonaidi-ship-it scope (must match org name).
# Reverted from @bainbridgebuilders scope 2026-05-03 per amended D20 — see CHANGELOG v1.0.3.
@samjonaidi-ship-it:registry=https://npm.pkg.github.com
# Token is set in CI via NODE_AUTH_TOKEN env; locally via ~/.npmrc with //npm.pkg.github.com/:_authToken=...
save-exact=false
engine-strict=true
